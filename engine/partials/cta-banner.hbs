  <!-- CTA Banner -->
  <section class="cta-banner">
    <div class="container">
      <h2>{{ctaBanner.title}}</h2>
      <p>{{ctaBanner.subtitle}}</p>
      <div class="cta-banner__actions">
        <a href="{{whatsappUrl contact.whatsapp.number contact.whatsapp.message}}" target="_blank" class="btn btn-white">
          <i class="{{ctaBanner.primaryCta.icon}}"></i> {{ctaBanner.primaryCta.label}}
        </a>
        <a href="{{ctaBanner.secondaryCta.href}}" class="btn btn-outline">
          {{ctaBanner.secondaryCta.label}}
        </a>
      </div>
    </div>
  </section>
