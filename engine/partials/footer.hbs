  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="footer__inner">

        <div>
          <div class="footer__logo">{{business.logoBefore}}<span>{{business.logoHighlight}}</span></div>
          <p class="footer__tagline">{{business.tagline}}</p>
          <div class="footer__social">
            {{#each social}}
            <a href="{{this.url}}" target="_blank" aria-label="{{this.label}}"><i class="{{this.icon}}"></i></a>
            {{/each}}
            <a href="https://wa.me/{{contact.whatsapp.number}}" target="_blank" aria-label="WhatsApp"><i class="fab fa-whatsapp"></i></a>
          </div>
        </div>

        <div class="footer__col">
          <h4>Services</h4>
          <ul class="footer__links">
            {{#each footer.serviceLinks}}
            <li><a href="{{this.href}}">{{this.label}}</a></li>
            {{/each}}
          </ul>
        </div>

        <div class="footer__col">
          <h4>Quick Links</h4>
          <ul class="footer__links">
            {{#each footer.quickLinks}}
            <li><a href="{{this.href}}">{{this.label}}</a></li>
            {{/each}}
          </ul>
        </div>

        <div class="footer__col">
          <h4>Contact</h4>
          <ul class="footer__links">
            <li><a href="tel:{{contact.phone.href}}">{{contact.phone.display}}</a></li>
            <li><a href="mailto:{{contact.email}}">{{contact.email}}</a></li>
            <li><a href="https://wa.me/{{contact.whatsapp.number}}" target="_blank">WhatsApp Us</a></li>
            <li><span class="footer__links-text">{{contact.address}}</span></li>
          </ul>
        </div>

      </div>

      <div class="footer__bottom">
        <p class="footer__copy">
          &copy; <span id="year"></span> {{business.name}}. All rights reserved.
        </p>
        <p class="footer__credit">
          {{footer.creditText}} <a href="{{footer.creditUrl}}" target="_blank">{{footer.creditName}}</a>
        </p>
      </div>
    </div>
  </footer>
